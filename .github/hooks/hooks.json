{
	"version": 1,
	"hooks": {
		"postToolUse": [
			{
				"type": "command",
				"bash": ".github/hooks/post-tool-lint.sh",
				"cwd": ".",
				"timeoutSec": 30
			}
		],
		"sessionEnd": [
			{
				"type": "command",
				"bash": ".github/hooks/session-end-tests.sh",
				"cwd": ".",
				"timeoutSec": 300
			}
		]
	}
}
